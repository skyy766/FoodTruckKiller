    },
    {
      "id": "informant",
      "type": "Informant",
      "probability": 0.10,
      "patienceSec": 60,
      "paymentMin": 5,
      "paymentMax": 5,
      "preferredRecipeId": ""
    },
    {
      "id": "target",
      "type": "Target",
      "probability": 0.05,
      "patienceSec": 120,
      "paymentMin": 0,
      "paymentMax": 0,
      "preferredRecipeId": ""
    }
  ]
